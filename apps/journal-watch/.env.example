# =============================================================================
# Journal Watch — app environment (apps/journalwatch/.env)
# Copy to .env and fill in every value before first boot.                                                                         
# =============================================================================                                                   
                                                                                                                                
# Docker Hub images                                                                                                               
JW_DOCKERHUB_NAMESPACE=your-dockerhub-namespace                                                                                 
JW_APP_TAG=latest                                                                                                                 
                                                                                                                                

# --- Django ------------------------------------------------------------------                                                   
                                                                                                                                
DJANGO_SETTINGS_MODULE=config.settings.production

# python -c "import secrets; print(secrets.token_urlsafe(64))"                                                                    
DJANGO_SECRET_KEY=
                                                                                                                                
# Comma-separated — include the apex domain and www if needed                                                                     
DJANGO_ALLOWED_HOSTS=[".journalwatch.org.au"]
                                                                                                                                
# TLS is terminated by Caddy — keep False                                                                                       
DJANGO_SECURE_SSL_REDIRECT=False                                                                                                  
                                                                                                                                
DJANGO_DEFAULT_FROM_EMAIL="Journal Watch <noreply@journalwatch.org.au>"
DJANGO_SERVER_EMAIL="Journal Watch <noreply@journalwatch.org.au>"                                                                 
                                                                                                                                
DJANGO_ADMIN_URL=secret-admin-path/                                                                                               
                                                                                                                                
DJANGO_ACCOUNT_ALLOW_REGISTRATION=True                                                                                            
                                                                                                                                
# Gunicorn workers — 2 × CPU cores + 1                                                                                            
WEB_CONCURRENCY=3
                                                                                                                                
                                                                                                                                
# --- PostgreSQL (Django) -----------------------------------------------------                                                   
                                                                                                                                
POSTGRES_DB=spanza_journal_watch
POSTGRES_USER=jw
# python -c "import secrets; print(secrets.token_urlsafe(24))"                                                                    
POSTGRES_PASSWORD=
                                                                                                                                
                                                                                                                                
# --- AWS (S3 media + SES email) ----------------------------------------------                                                   
                                                                                                                                
DJANGO_AWS_ACCESS_KEY_ID=                                                                                                       
DJANGO_AWS_SECRET_ACCESS_KEY=
DJANGO_AWS_STORAGE_BUCKET_NAME=your-bucket-name
DJANGO_AWS_S3_REGION_NAME=ap-southeast-2
DJANGO_AWS_DEFAULT_REGION=ap-southeast-2                                                                                          

# SES inbound email prefix in S3                                                                                                  
DJANGO_ANYMAIL_INBOUND_S3_OBJECT_PREFIX=email                                                                                   
                                                                                                                                
# SNS webhook signing secret                                                                                                      
WEBHOOK_SECRET=                                                                                                                   
                                                                                                                                
                                                                                                                                
# --- Celery / Flower ---------------------------------------------------------
                                                                                                                                
CELERY_FLOWER_USER=flower                                                                                                       
CELERY_FLOWER_PASSWORD=

                                                                                                                                
# --- Sentry (optional) -------------------------------------------------------
                                                                                                                                
SENTRY_DSN=                                                                                                                     
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
                                                                                                                                
                                                                                                                                
# --- OIDC (Django as OAuth2/OIDC provider for Planka) ------------------------                                                   
                                                                                                                                
# openssl genrsa 4096 | base64 -w 0                                                                                               
OIDC_RSA_PRIVATE_KEY=
                                                                                                                                
# Public URL of the Django OIDC endpoint                                                                                          
OIDC_ISS_ENDPOINT=https://journalwatch.org.au/o
                                                                                                                                
                                                                                                                                
# --- Planka integration (Django → Planka API) --------------------------------
                                                                                                                                
PLANKA_EXTERNAL_URL=https://planka.journalwatch.org.au                                                                          
PLANKA_ADMIN_EMAIL=admin@journalwatch.org.au
                                                                                                                                

# --- Planka application ------------------------------------------------------                                                   
                                                                                                                                
BASE_URL=https://planka.journalwatch.org.au

# openssl rand -hex 32                                                                                                            
SECRET_KEY=
                                                                                                                                
USER_TERMS_OF_SERVICE_VERSION=1                                                                                                   

OIDC_CLIENT_ID=planka-production                                                                                                  
# openssl rand -hex 32  (must match the client created by setup_planka_oidc)                                                    
OIDC_CLIENT_SECRET=                                                                                                               
OIDC_USE_DEFAULT_RESPONSE_MODE=true
OIDC_SCOPES=openid email profile                                                                                                  
OIDC_EMAIL_ATTRIBUTE=email                                                                                                        
OIDC_NAME_ATTRIBUTE=name
OIDC_IGNORE_USERNAME=true                                                                                                         
OIDC_IGNORE_ROLES=true
OIDC_ENFORCED=true                                                                                                              
                                                                                                                                
DEFAULT_ADMIN_NAME=Journal Watch Admin                                                                                            
DEFAULT_ADMIN_USERNAME=admin                                                                                                    
# Set once at first boot, then remove:                                                                                            
DEFAULT_ADMIN_PASSWORD=                                                                                                           

                                                                                                                            
# --- Planka S3 attachments (separate IAM user, scoped to attachments/* only) -                                                 
                                                                                                                            
PLANKA_S3_ACCESS_KEY_ID=                                                                                                        
PLANKA_S3_SECRET_ACCESS_KEY=
PLANKA_S3_REGION=ap-southeast-2
